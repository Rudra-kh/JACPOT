{
  "name": "jacpote",
  "version": "1.0.0",
  "description": "",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "dbus-next": "^0.10.2",
    "electron-store": "^11.0.2",
    "express": "^5.2.1",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.576.0",
    "multer": "^2.1.1",
    "node-vibrant": "^3.1.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "systeminformation": "^5.31.1",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "build": {
    "appId": "com.jacpote.app",
    "productName": "JACPOTE",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
